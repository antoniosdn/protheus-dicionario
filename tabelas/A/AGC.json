{"tabela":"AGC","nome":"Regras monitor. Service Desk","nome_eng":"Service Desk Monitor.Rules","modo":"C","arquivo":"AGC990","campos":[{"campo":"AGC_FILIAL","titulo":"Filial","tipo":"C","tam":2,"dec":0},{"campo":"AGC_COD","titulo":"Codigo","tipo":"C","tam":8,"dec":0,"ini_padrao":"TKNUMERO('AGC','AGC_COD')"},{"campo":"AGC_DESCRI","titulo":"Descricao","tipo":"C","tam":200,"dec":0},{"campo":"AGC_CODENT","titulo":"Cliente","tipo":"C","tam":25,"dec":0},{"campo":"AGC_CODSB1","titulo":"Produto","tipo":"C","tam":15,"dec":0,"validacao":"Empty(M->AGC_CODSB1) .OR. ExistCpo('SB1')"},{"campo":"AGC_SEVCOD","titulo":"Criticidade","tipo":"C","tam":1,"dec":0,"validacao":"Empty(M->AGC_SEVCOD) .OR. Pertence('12345')","combo":"5=Crítica;4=Alta;3=Média;2=Baixa;1=Requisição de alteração de especificação"},{"campo":"AGC_STATUS","titulo":"Status","tipo":"C","tam":1,"dec":0,"validacao":"Pertence('12')","combo":"1=Ativo;2=Inativo"},{"campo":"AGC_CODORI","titulo":"Cod. Origem","tipo":"C","tam":8,"dec":0,"validacao":"EMPTY(M->AGC_CODORI) .OR. FQNCNTAB('3',M->AGC_CODORI,.T.)"},{"campo":"AGC_CODEFE","titulo":"Cod. Efeitos","tipo":"C","tam":8,"dec":0,"validacao":"EMPTY(M->AGC_CODEFE) .OR. FQNCNTAB('2',M->AGC_CODEFE,.T.)"},{"campo":"AGC_CODCAT","titulo":"Cod. Categ.","tipo":"C","tam":8,"dec":0,"validacao":"EMPTY(M->AGC_CODCAT) .OR. FQNCNTAB('4',M->AGC_CODCAT,.T.)"},{"campo":"AGC_CODCAU","titulo":"Cod. Causa","tipo":"C","tam":8,"dec":0,"validacao":"EMPTY(M->AGC_CODCAU) .OR. FQNCNTAB('1',M->AGC_CODCAU,.T.)"},{"campo":"AGC_EVENTO","titulo":"Evento","tipo":"C","tam":1,"dec":0,"validacao":"Pertence('12345678')","combo":"1=Abertura;2=Atualização;3=Encerramento;4=Geração de FNC;5=Transferencia Equipe;6=Inicio SLA;7=Pausa SLA;8=Fim SLA"},{"campo":"AGC_GRUPO","titulo":"Equipe","tipo":"C","tam":2,"dec":0,"validacao":"Empty(M->AGC_GRUPO) .OR. ExistCpo('SU0')"},{"campo":"AGC_INIVIG","titulo":"Ini Vigencia","tipo":"D","tam":8,"dec":0,"validacao":"IIF( !Empty(M->AGC_FIMVIG), (M->AGC_FIMVIG > M->AGC_INIVIG), .T.)